<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/plugwatch/db" VERSION="20260710" COMMENT="XMLDB file for local_plugwatch"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd">
  <TABLES>
    <TABLE NAME="local_plugwatch_items" COMMENT="Plugins each user is watching for updates">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="FK to mdl_user.id"/>
        <FIELD NAME="component" TYPE="char" LENGTH="100" NOTNULL="true" SEQUENCE="false" COMMENT="Frankenstyle component name e.g. block_xp"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="fk_userid" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="uq_userid_component" UNIQUE="true" FIELDS="userid, component"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_plugwatch_state" COMMENT="Last known version and notification state per user-plugin pair">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="FK to mdl_user.id"/>
        <FIELD NAME="component" TYPE="char" LENGTH="100" NOTNULL="true" SEQUENCE="false" COMMENT="Frankenstyle component name"/>
        <FIELD NAME="timelastreleased" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"
            COMMENT="Unix timestamp from Plugin Directory API"/>
        <FIELD NAME="releasename" TYPE="char" LENGTH="100" NOTNULL="false" SEQUENCE="false"
            COMMENT="Human-readable release string e.g. v2.5.1"/>
        <FIELD NAME="timelastnotified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"
            COMMENT="When the last notification was sent to this user"/>
        <FIELD NAME="timechecked" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"
            COMMENT="When the last update check was performed"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="fk_userid" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="uq_userid_component" UNIQUE="true" FIELDS="userid, component"/>
        <INDEX NAME="ix_timechecked" UNIQUE="false" FIELDS="timechecked"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_plugwatch_newplugins" COMMENT="Global log of plugins discovered in the Plugin Directory, used by the new-plugins digest">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="component" TYPE="char" LENGTH="100" NOTNULL="true" SEQUENCE="false"
            COMMENT="Frankenstyle component name, one row per plugin ever discovered"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false"
            COMMENT="Display name captured at discovery time"/>
        <FIELD NAME="timelastreleased" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"
            COMMENT="timelastreleased from the Plugin Directory API at discovery time"/>
        <FIELD NAME="timediscovered" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"
            COMMENT="When this task first saw the component"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="uq_component" UNIQUE="true" FIELDS="component"/>
        <INDEX NAME="ix_timediscovered" UNIQUE="false" FIELDS="timediscovered"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
