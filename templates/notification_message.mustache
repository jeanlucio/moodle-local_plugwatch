{{!
    @template local_plugwatch/notification_message

    HTML body for the "plugin update available" notification message sent via the
    Moodle Message API. Renders the plugin name, new version, optional AI summary
    and a link to the Plugin Directory.

    Classes required:
    * none — uses only Bootstrap and Moodle utility classes.

    Data attributes required:
    * none.

    Example context (json):
    {
        "pluginname": "XP — Gamification",
        "component": "block_xp",
        "release": "v24.12.0",
        "hassummary": true,
        "summaryhtml": "<p>This release fixes a score-reset bug and adds a new leaderboard widget.</p>",
        "directoryurl": "https://moodle.org/plugins/block_xp",
        "hasreleaseurl": true,
        "releaseurl": "https://github.com/moodleusp/moodle-block_xp/releases/tag/v24.12.0"
    }
}}
<div class="local-plugwatch-notification">
    <h2 class="h4 mt-0 mb-3">
        {{pluginname}}
        <span class="badge bg-success text-white ms-2 me-2">{{release}}</span>
    </h2>

    <p class="mb-2">
        <small class="text-muted">
            <code>{{component}}</code>
        </small>
    </p>

    {{#hassummary}}
    <div class="local-plugwatch-summary card card-body bg-light mb-3" role="note">
        {{{summaryhtml}}}
    </div>
    {{/hassummary}}

    <div class="local-plugwatch-actions mt-3">
        <a href="{{directoryurl}}"
           class="btn btn-primary btn-sm me-2"
           target="_blank"
           rel="noopener noreferrer">
            {{#str}}pluginname, local_plugwatch{{/str}}
        </a>
        {{#hasreleaseurl}}
        <a href="{{releaseurl}}"
           class="btn btn-outline-secondary btn-sm"
           target="_blank"
           rel="noopener noreferrer">
            {{#str}}releasenotes, local_plugwatch{{/str}}
        </a>
        {{/hasreleaseurl}}
    </div>
</div>
