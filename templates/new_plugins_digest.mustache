{{!
    @template local_plugwatch/new_plugins_digest

    HTML body for the consolidated "new plugins digest" notification message sent
    via the Moodle Message API. Lists every plugin newly published in the Plugin
    Directory since the user's last digest, in a single e-mail.

    Classes required:
    * none — uses only Bootstrap and Moodle utility classes.

    Data attributes required:
    * none.

    Example context (json):
    {
        "count": 2,
        "introtext": "2 new plugins were published in the Plugin Directory since your last digest:",
        "plugins": [
            {"name": "XP — Gamification", "component": "block_xp", "directoryurl": "https://moodle.org/plugins/block_xp"},
            {"name": "Game", "component": "mod_game", "directoryurl": "https://moodle.org/plugins/mod_game"}
        ]
    }
}}
<div class="local-plugwatch-digest">
    <p class="mb-3">{{introtext}}</p>

    <ul class="list-unstyled mb-0">
        {{#plugins}}
        <li class="mb-2">
            <a href="{{directoryurl}}" target="_blank" rel="noopener noreferrer">{{name}}</a>
            <small class="text-muted">(<code>{{component}}</code>)</small>
        </li>
        {{/plugins}}
    </ul>
</div>
